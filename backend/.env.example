# ─────────────────────────────────────────────────────────────────────────────
# Author Studio Pro — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ─── API Security ───────────────────────────────────────────────
# Leave empty for open demo mode. Set a strong secret key for production.
# API_KEY=your-secret-api-key-here

# ─── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ─── Security ───────────────────────────────────────────────────
# Maximum file upload size in MB
MAX_FILE_SIZE_MB=25

# ─── AI (optional — users supply their own key via the UI) ──────
# DEFAULT_AI_MODEL=mistralai/mistral-7b-instruct:free
